{
    "name": "ytdown",
    "version": "1.0.0",
    "description": "YouTube Video Downloader",
    "main": "main.js",
    "author": "benteckxyz",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder --win",
        "pack": "electron-builder --win --dir"
    },
    "build": {
        "appId": "com.benteck.ytdown",
        "productName": "YTDown",
        "win": {
            "target": [
                { "target": "nsis", "arch": ["x64"] },
                { "target": "portable", "arch": ["x64"] }
            ],
            "icon": "icon.ico"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "files": [
            "main.js",
            "preload.js",
            "renderer/**/*",
            "package.json",
            "icon.ico",
            "icon.png"
        ],
        "directories": {
            "output": "dist"
        }
    },
    "devDependencies": {
        "electron": "^35.0.0",
        "electron-builder": "^26.8.1"
    }
}